# Drunkard production environment example.
# Copy this file to `.env.production` on the server and replace every placeholder.
# Never commit `.env.production` or real secrets.

NODE_ENV=production

# PostgreSQL
DB_PASSWORD=replace_with_a_strong_database_password

# JWT signing secret. Use a long random value, for example: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret

# Registration / admin bootstrap
INVITE_CODE=replace_with_private_invite_code
ADMIN_PHONE=replace_with_admin_phone
ADMIN_PASSWORD=replace_with_admin_password

# Public URLs used by redirects, CORS and uploaded asset resolution.
# Examples:
#   SERVER_URL=https://bar.example.com
#   FRONTEND_URL=https://bar.example.com
#   CORS_ORIGINS=https://bar.example.com
# Temporary IP + port testing is also possible:
#   SERVER_URL=http://YOUR_SERVER_IP:18080
SERVER_URL=https://bar.example.com
FRONTEND_URL=https://bar.example.com
CORS_ORIGINS=https://bar.example.com

# WeChat OAuth. Keep empty if WeChat login is not configured.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
